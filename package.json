  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1",
    "allure": "^3.8.2",
    "allure-playwright": "^3.8.0"
  },
  "dependencies": {
    "@cucumber/cucumber": "^12.8.0",
    "exceljs": "^3.4.0",
    "xlsx": "^0.18.5"
  }
}
