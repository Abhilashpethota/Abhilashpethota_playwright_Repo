{
  "name": "playwright",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "regression": "npx playwright test",
    "WebTests": "npx playwright test  --grep @Web",
    "APItests": "npx playwright test  --grep @API",
    "generate:report": "allure generate allure-results --clean -o allure-report",
    "open:report": "allure open allure-report",
    "test": "npm run regression && npm run generate:report && npm run open:report",
    "multipleworkers": "npx playwright test --config=playwright.config1.js --workers=4"
  },
